# ====================
# CourtMate Backend Environment Configuration
# ====================
# Copy this file to .env and update values for your environment

# ====================
# Application Settings
# ====================
ENVIRONMENT=development
GIN_MODE=debug
PORT=8000

# ====================
# Database Configuration
# ====================
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=rootpassword
DB_NAME=courtmate_db

# ====================
# Authentication & Security
# ====================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
# NOTE: Generate a strong secret key for production!

# ====================
# Frontend Configuration
# ====================
FRONTEND_URL=http://localhost:5173

# ====================
# External APIs
# ====================
RESEND_API_KEY=your_resend_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ====================
# Redis Configuration
# ====================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=        # Leave empty if no authentication required

# ====================
# RabbitMQ Configuration
# ====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# Full URL alternative (if you prefer):
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ====================
# Testing Configuration
# ====================
TEST_DATABASE_URL=postgresql://postgres:rootpassword@localhost:5432/courtmate_test
BASE_URL=http://localhost:8000
RABBITMQ_TEST_URL=amqp://guest:guest@localhost:5672
