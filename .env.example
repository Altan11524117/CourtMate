# ====================
# CourtMate Environment Configuration
# ====================
# Copy this file to .env and update values for your environment
# NOTE: Never commit .env file to git!

# ====================
# Application Environment
# ====================
ENVIRONMENT=development
GIN_MODE=debug

# ====================
# Database Configuration
# ====================
DB_USER=postgres
DB_PASSWORD=rootpassword
DB_NAME=courtmate_db

# ====================
# RabbitMQ Configuration
# ====================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ====================
# Security & Authentication
# ====================
# IMPORTANT: Change this in production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ====================
# Frontend Configuration
# ====================
FRONTEND_URL=http://localhost:5173

# ====================
# External Services (Optional)
# ====================
# Resend API for Email
RESEND_API_KEY=your_resend_api_key_here

# Groq API for AI Features
GROQ_API_KEY=your_groq_api_key_here

# ====================
# Production Recommendations
# ====================
# For production, create a separate .env file with:
# - Strong JWT_SECRET (use 'openssl rand -base64 32')
# - Strong database password
# - Real API keys for external services
# - Set ENVIRONMENT=production
# - Set GIN_MODE=release
